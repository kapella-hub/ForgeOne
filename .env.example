# ForgeOne env template — copy to .env and fill in.
# Every var is prefixed HL_ (hyperliquid bucket) or FORGE_ (global).

# --- Global ---
FORGE_LOG_LEVEL=INFO
FORGE_DATA_DIR=/opt/forgeone/data

# --- Hyperliquid paper (Phase 1) ---
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_REST_URL=https://api.hyperliquid.xyz
HL_BUCKET_ID=hyperliquid_paper
HL_STARTING_BANKROLL_USD=10000
HL_NOTIONAL_USD=10000
HL_LEVERAGE=3
HL_TAKER_FEE_BPS=2.5
HL_SLIPPAGE_BPS=1.5
HL_DAILY_LOSS_CAP_PCT=0.20
HL_CIRCUIT_LOSS_THRESHOLD=3
HL_CIRCUIT_COOLDOWN_PERIODS=4

# --- Binance WS (BTC + ETH price feed for continuation signal) ---
FORGE_BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# --- NexusStack (already live on VPS) ---
FORGE_NEXUS_RELAY_URL=http://localhost:8080
FORGE_NEXUS_POST_DAILY=true

# --- Paper-only toggle (Phase 1 == true; Phase 2 flips this to false) ---
HL_PAPER_ONLY=true

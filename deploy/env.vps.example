# VPS (Malaysia) production env for ForgeOne paper trading.
# Copy to /opt/forgeone/.env after deploy.

FORGE_LOG_LEVEL=INFO
FORGE_DATA_DIR=/opt/forgeone/data

# Malaysia VPS is NOT geo-blocked by Binance.com — use the primary endpoint.
FORGE_BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# Hyperliquid — global, no geo block
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_REST_URL=https://api.hyperliquid.xyz
HL_BUCKET_ID=hyperliquid_paper

# Phase 2 only — wallet identity. Public address here is OK; private key is NOT.
# Private key must be injected via systemd EnvironmentFile with 0600 perms, or
# better, fetched from a secret manager at process start.
HL_WALLET_ADDRESS=
# HL_WALLET_PRIVATE_KEY=

HL_STARTING_BANKROLL_USD=10000
HL_NOTIONAL_USD=10000
HL_LEVERAGE=3
HL_TAKER_FEE_BPS=2.5
HL_SLIPPAGE_BPS=1.5
HL_DAILY_LOSS_CAP_PCT=0.20
HL_CIRCUIT_LOSS_THRESHOLD=3
HL_CIRCUIT_COOLDOWN_PERIODS=4
HL_PAPER_ONLY=true

# NexusStack is already live on this VPS (per memory).
FORGE_NEXUS_RELAY_URL=http://localhost:8080
FORGE_NEXUS_POST_DAILY=true
